---
import { siteConfig } from '../config/site';
---

<header class="border-b border-neutral-100 bg-white">
  <div class="content-wrap flex items-center justify-center py-5">
    <a href="/" class="inline-flex items-center gap-3 no-underline">
      <img
        src="/content/images/2024/04/logo@2x.png"
        alt={siteConfig.name}
        class="h-10 w-auto md:h-12"
        width="120"
        height="48"
      />
    </a>
  </div>
</header>
