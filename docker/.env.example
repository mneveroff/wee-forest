# Copy to .env next to docker-compose.yml and fill in values.
# Secrets stay on the server — they are read at container runtime, not baked into the image.

DOCKER_MY_NETWORK=wee_forest_net
DOCKERHUB_USERNAME=mneveroff
IMAGE_TAG=latest

# Required secrets (runtime)
MAPBOX_TOKEN=
POSTHOG_PUBLIC_API_KEY=
POSTHOG_API_KEY=

# Server paths (defaults match production)
STATIC_SERVER_PATH=lens
AREA_SERVER_PATH=area
TILE_SERVER_PATH=tiles
# Browser clients on / and /lens both send to /ingest (first-party proxy).
POSTHOG_PROXY_PATH=ingest
POSTHOG_HOST=https://eu.i.posthog.com

# Public origin for tileserver-gl metadata URLs
TILE_SERVER_HOST=https://weeforest.org

# Data paths inside the container (match volume mounts in docker-compose.yml)
PARQUET_PATH=/repo/lens/data/area
TILES_PATH=/repo/lens/data/tiles
DUCKDB_PATH=/repo/lens/data/area/wee_forest.duckdb
STATIC_DIR=../public
SITE_DIST_PATH=/repo/site/dist

RECREATE_DATABASE=false
NODE_ENV=production
AREA_PORT=3939
